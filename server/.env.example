# ---- 服务 ----
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# 客户端访问应用级 token（防滥用，非用户身份）。逗号分隔可配多个。
APP_TOKENS=dev-token-change-me

# ---- 限流 ----
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute

# ---- 缓存 ----
CACHE_TTL_MS=604800000
# 内容版本号，参与缓存键；模板/文案整体更新时自增以失效旧缓存
CONTENT_VERSION=1

# ---- LLM provider 选择 ----
# 主 provider 与降级链（逗号分隔，按序切换）
LLM_PRIMARY=anthropic
LLM_FALLBACKS=openai
# 单次调用超时（毫秒）
LLM_TIMEOUT_MS=8000

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01

# ---- OpenAI 协议（可指向 OpenAI / 兼容端点 / 自建 vLLM/Ollama）----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
