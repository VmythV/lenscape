{
  "name": "lenscape-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "镜界 Lenscape 后端代理 (BFF)：保管 LLM 密钥、统一 provider、限流/缓存/降级",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.2",
    "ajv": "^8.17.1",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
